# Campaign Manager — environment variables
#
# Copy this file to .env.local for local development, replacing the
# placeholder values with real ones. For production, set these same keys
# in the Vercel dashboard (Settings → Environment Variables).
#
# NEVER commit a populated copy of this file to git. .env.local is gitignored.

# Supabase project URL — find under Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — SERVER ONLY. Bypasses RLS. Never expose
# to the browser; used by lib/supabase/admin.ts for trusted operations.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres connection string for Drizzle. Use the Supabase Transaction Pooler
# (port 6543) for application reads/writes — required for serverless (Vercel):
# it releases connections per-transaction, whereas the Session Pooler (port
# 5432) holds one per client and saturates the connection limit under
# concurrent serverless load. The `?prepare=false` flag is required for
# postgres-js + Supabase pooler compatibility.
#
# Special characters in the password (#, &, etc.) must be URL-encoded,
# OR rotate the password to alphanumerics. # specifically gets parsed as
# a URL fragment and silently truncates the connection string — easy to
# miss, hard to debug.
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?prepare=false

# Public site URL — origin where the app is served. Used for Supabase
# auth callback URLs and as the base when building absolute links.
# Local: http://localhost:3001
# Production: https://<your-vercel-deployment>.vercel.app (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ============================================================
# Spam scoring
# ============================================================
# Which provider to use. 'classifier' is the only option in step 8a.
SPAM_PROVIDER=classifier

# Cloud Run URL of the SMS Spam Classifier service. Server-side only.
CLASSIFIER_URL=

# API key the classifier service was deployed with. Sent as X-API-Key
# header on every /score call. Server-side only.
CLASSIFIER_API_KEY=

# Per-attempt fetch timeout (ms) for the /score call. Optional, default
# 25000. The provider retries once on a timeout/network error, so the
# worst case is ~2× this; the /api/spam/score route's maxDuration=60
# bounds it. Raised from 10000 to let a cold (scaled-to-zero) classifier
# boot + load its model before we abort. If the classifier is always-on
# (e.g. self-hosted), a lower value is fine.
CLASSIFIER_TIMEOUT_MS=25000

# ============================================================
# Click scoring (link shortener Phase 3)
# ============================================================
# MaxMind GeoLite2 license key — server-side only. Used by lib/links/geoip.ts
# to fetch the GeoLite2-ASN (+ Country) .mmdb at runtime for ASN/datacenter
# enrichment. The .mmdb is NEVER committed (GeoLite license forbids it). With
# this UNSET, scoring still runs but only on UA signals (asn/country/
# is_datacenter stay NULL); add the key later and run a re-score pass.
MAXMIND_LICENSE_KEY=

# Shared secret protecting the cron-triggered scoring endpoint
# (/api/clicks/score-pending). Vercel Cron sends it as `Authorization: Bearer
# <CRON_SECRET>`. Set the SAME value here and in the Vercel dashboard. Without
# it the endpoint returns 503 (treated as misconfigured), so set it before
# relying on scheduled scoring. Also gates the send drain (Step 3).
CRON_SECRET=

# ============================================================
# Provider credential encryption (multi-account, migration 0110)
# ============================================================
# 32-byte base64 master key for AES-256-GCM encryption of provider_credentials
# (TextHub/Ahoi API keys) at rest. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# MUST be the SAME value in Vercel (all envs) and every local .env.local that
# runs a script touching provider_credentials (backfill, or a dev drain/poller
# that decrypts) — a mismatch makes existing rows silently fail to decrypt,
# not error at write time. Never commit a value.
PROVIDER_CREDENTIALS_KEY=

# ============================================================
# SMS sending (TextHub) — link shortener Phase: send pipeline
# ============================================================
# Global kill-switch for the send DRAIN. Must be exactly "true" for any SMS to
# go out; anything else halts the drain (checked on every invocation, including
# between batches mid-drain, so flipping it off stops an in-progress send).
# Default OFF. The TextHub api_key itself is NOT here — it's stored per provider
# in the provider_credentials table (multi-tenant), not as a global env var.
SEND_ENABLED=false

# Tier-1 alerting over Telegram (circuit-breaker trips, opt-out poller
# failures). BEST-EFFORT: if either var is unset the alerter is a silent no-op
# and the drain/poller run unaffected. Create a bot via @BotFather for the
# token; TELEGRAM_CHAT_ID is the numeric chat/group id to send alerts to.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# SMS sending (Ahoi / api19-CallAPI white-label) — Phase 1 Section 2
# ============================================================
# Optional base-URL override for the Ahoi/api19 platform (defaults to
# https://v1.api19.com). The Ahoi api_key itself is NOT here — it's stored
# per provider in provider_credentials (multi-tenant), same as TextHub's.
# AHOI_API_BASE_URL=https://v1.api19.com

# One-time seed token for scripts/seed-ahoi-number-credential.ts, which
# copies it into provider_credentials.api_key. Not read by the app at
# runtime after seeding — remove once the seed has run.
# AHOI_API_TOKEN=

# DLR reject-rate circuit-breaker tuning (Section 3). Defaults 10 / 900 —
# leave unset to use them. The DLR `rejected` signal is provisional (never
# observed live in recon); these let ops tune sensitivity without a redeploy.
# AHOI_DLR_REJECT_SPIKE_THRESHOLD=10
# AHOI_DLR_REJECT_SPIKE_WINDOW_SEC=900

# ============================================================
# SimpleTexting (provider integration — Phase 1 skeleton)
# ============================================================
# Optional base-URL override for the SimpleTexting API (defaults to
# https://api-app2.simpletexting.com/v2). The SimpleTexting API token is NOT
# here — it's stored per account in provider_credentials (encrypted), entered
# via the provider Accounts UI, same as TextHub/Ahoi.
# SIMPLETEXTING_API_BASE_URL=https://api-app2.simpletexting.com/v2

# ============================================================
# Keitaro tracker — 5-minute results poll (lib/keitaro/)
# ============================================================
# Dedicated admin/API host (stable, independent of brand tracking domains).
# Keep it DNS-only in Cloudflare (or WAF-except /admin_api/) so the every-5-min
# programmatic calls aren't bot-challenged. Optional — defaults to the value
# below if unset.
KEITARO_API_URL=https://admin.gdkn.org
# Keitaro Admin API key (Users → Admin API Keys). Sent as the `Api-Key` header.
# Never commit a real value. ROTATE the key that was shared in plaintext during
# setup. With this UNSET the poll returns degraded:true (logs + retries next
# cycle) and never writes. Required for the poll to do anything.
KEITARO_API_KEY=

# ============================================================
# Telnyx Number Lookup — carrier/line-type enrichment (lib/telnyx/)
# ============================================================
# Telnyx API v2 key (Auth → API Keys). Sent as `Authorization: Bearer <key>`.
# Never commit a real value. With this UNSET the lookup worker no-ops (logs +
# leaves queue rows pending). The account must have "Permitted NPAC User"
# enabled for full LRN/portability data. Required for lookups to run.
TELNYX_API_KEY=
# Optional base-URL override (defaults to https://api.telnyx.com). Trailing
# slashes are stripped.
# TELNYX_API_URL=https://api.telnyx.com

# ============================================================
# Anthropic API — carrier auto-classification triage (lib/carrier/ai-triage.ts)
# ============================================================
# Claude API key (console.anthropic.com). Used ONLY by the async carrier-triage
# cron to bucket unresolved carrier strings (never in the inline lookup/upload
# path). With this UNSET the triage cron no-ops; sends continue under the Unmapped
# policy. Read automatically by @anthropic-ai/sdk from this exact var name.
ANTHROPIC_API_KEY=

# ============================================================
# Local development only — do NOT set these in production
# ============================================================
# Test credentials for scripts/test-*-api.ts. Set temporarily when
# running the test suites against a local dev server, then remove.
# TEST_USER_EMAIL=you@example.com
# TEST_USER_PASSWORD=
